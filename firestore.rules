rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /orders/{orderId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if request.auth != null && request.auth.token.email == 'fayismuhammed001@gmail.com';
    }
    match /contacts/{contactId} {
      allow create: if true;
      allow read: if request.auth != null && request.auth.token.email == 'fayismuhammed001@gmail.com';
    }
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == 'fayismuhammed001@gmail.com';
    }
  }
}
